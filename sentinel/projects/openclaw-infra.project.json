{
  "id": "openclaw-infra",
  "name": "OpenClaw Infra",
  "color": "oklch(0.65 0.18 30)",
  "summary": "Infraestructura pròpia d'Axis (gateway, chat-bridge, Caddy, endpoints públics). Vigilada per Sentinel.",
  "status": "active",
  "agents": ["axis", "sentinel"],
  "skills": [],
